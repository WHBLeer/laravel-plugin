{
    "name": "sanlilin/laravel-plugin",
    "license": "MIT",
    "minimum-stability": "stable",
    "authors": [
        {
            "name": "wanghongbin",
            "email": "wanghongbin816@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Sanlilin\\LaravelPlugin\\": "src/"
        },
        "files": [
            "src/Support/PluginHelper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Sanlilin\\LaravelPlugin\\Tests\\": "tests",
            "PluginsTest\\": "tests/stubs/valid/"
        }
    },
    "require": {
        "php": "^8.2",
        "ext-zip": "*",
        "laravel/framework": "^11.0",
        "spatie/laravel-permission": "^6.12"
    },
    "require-dev": {
        "phpunit/phpunit": "^8.0",
        "orchestra/testbench": "^4.0|^5.0|^6.0"
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Sanlilin\\LaravelPlugin\\Providers\\PluginServiceProvider"
            ],
            "aliases": {
                "PluginManager": "Sanlilin\\LaravelPlugin\\Facades\\PluginManager"
            }
        }
    }
}
