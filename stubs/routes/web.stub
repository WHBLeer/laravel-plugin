<?php
use Illuminate\Support\Facades\Route;
use $CLASS_NAMESPACE$\$STUDLY_NAME$Controller;
use $PLUGIN_NAMESPACE$\$PLUGIN$\$CONTROLLER_NAMESPACE$\$STUDLY_NAME$Controller;
/*
|--------------------------------------------------------------------------
| Web Routes
|--------------------------------------------------------------------------
|
| Here is where you can register web routes for your application. These
| routes are loaded by the RouteServiceProvider within a group which
| contains the "web" middleware group. Now create something great!
|
*/

/**
 * 前端
 */
Route::prefix('$LOWER_NAME$')->group(function() {
    Route::get('/', [$STUDLY_NAME$Controller::class,'index'])->name('$LOWER_NAME$');
});

/**
 * 后端
 */
Route::group(['as' =>'seller.','prefix'=>'seller','middleware'=>['auth','seller']],function(){
    Route::prefix('$LOWER_NAME$')->group(function() {
        Route::get('/', [$STUDLY_NAME$Controller::class,'index'])->name('$LOWER_NAME$');
        Route::any('$LOWER_NAME$/create', [$STUDLY_NAME$Controller::class,'create'])->name('$LOWER_NAME$.create');
        Route::get('$LOWER_NAME$/{id}/show', [$STUDLY_NAME$Controller::class,'show'])->name('$LOWER_NAME$.show');
        Route::get('$LOWER_NAME$/{id}/edit', [$STUDLY_NAME$Controller::class,'edit'])->name('$LOWER_NAME$.edit');
        Route::put('$LOWER_NAME$/{id}/update', [$STUDLY_NAME$Controller::class,'update'])->name('$LOWER_NAME$.update');
        Route::post('$LOWER_NAME$/{id}/save', [$STUDLY_NAME$Controller::class,'save'])->name('$LOWER_NAME$.save');
        Route::post('$LOWER_NAME$/destroy', [$STUDLY_NAME$Controller::class,'destroy'])->name('$LOWER_NAME$.destroy');

    });
});